{
  "name": "cookbook-mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild:ios": "expo prebuild --platform ios --no-install",
    "ios:reinstall": "expo run:ios --no-build-cache",
    "web": "expo start --web",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:i18n": "vitest run scripts/check-i18n-parity.test.ts",
    "generate:api": "openapi-typescript ../SharedCookbook/src/Web/wwwroot/api/specification.json -o services/api/generated/schema.d.ts && prettier --write services/api/generated/schema.d.ts",
    "deploy:ios:prod": "bash .cursor/skills/apple-upload/scripts/deploy.sh",
    "deploy:android:prod": "bash .cursor/skills/android-upload/scripts/deploy.sh"
  },
  "dependencies": {
    "@expo-google-fonts/playpen-sans": "^0.4.1",
    "@expo-google-fonts/space-grotesk": "^0.4.1",
    "@expo/react-native-action-sheet": "^4.1.1",
    "@expo/vector-icons": "^15.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.14",
    "@react-navigation/native": "^7.1.8",
    "@sentry/react-native": "^7.2.0",
    "@shopify/flash-list": "2.0.2",
    "@tanstack/query-sync-storage-persister": "^5.100.14",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-persist-client": "^5.100.14",
    "date-fns": "^4.1.0",
    "expo": "~54.0.34",
    "expo-apple-authentication": "~8.0.8",
    "expo-application": "^7.0.8",
    "expo-build-properties": "^1.0.10",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "^8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "^17.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.12",
    "expo-localization": "^17.0.8",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "^15.0.8",
    "expo-speech-recognition": "^3.1.2",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-web-browser": "~15.0.11",
    "i18next": "^25.10.10",
    "intl-pluralrules": "^2.0.1",
    "openapi-fetch": "^0.17.0",
    "openapi-typescript": "^7.13.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.72.1",
    "react-i18next": "^16.6.6",
    "react-native": "0.81.5",
    "react-native-edge-to-edge": "^1.8.1",
    "react-native-fbsdk-next": "^13.4.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-mmkv": "4.1.2",
    "react-native-nitro-modules": "^0.33.9",
    "react-native-purchases": "^10.1.2",
    "react-native-purchases-ui": "^10.1.2",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.6.1",
    "yup": "^1.7.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@react-native-community/cli": "20.1.1",
    "@sentry/cli": "2.55.0",
    "@types/react": "~19.1.17",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^10.0.0",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "~5.9.3",
    "vitest": "^4.1.7"
  },
  "private": true,
  "expo": {
    "install": {
      "exclude": [
        "react-native-worklets"
      ]
    }
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "onlyBuiltDependencies": [
    "@sentry/cli"
  ]
}
